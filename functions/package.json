{
  "name": "functions",
  "description": "Push notification delivery for giggre_app (Firestore triggers -> FCM)",
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions:onChatMessageCreated,functions:onOpenGigPosted,functions:onApplicantNotificationCreated,functions:onGigOfferCreated,functions:onTicketUpdated,functions:onVerificationStatusChanged,functions:onSkillRequestStatusChanged,functions:onQuickGigProgress,functions:onOpenGigProgress,functions:onOfferedGigProgress,functions:onQuickGigAssigned,functions:onOpenGigAssigned,functions:onOfferedGigAssigned,functions:checkExpiredGigSchedules,functions:sendDailyTestReminder,functions:publishVersionAnnouncement"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.3.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "private": true
}
